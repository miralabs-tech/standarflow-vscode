{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "outDir": "dist/.tsbuild/scripts",
    "tsBuildInfoFile": "dist/.tsbuild/scripts.tsbuildinfo"
  },
  "include": ["scripts/**/*"]
}
